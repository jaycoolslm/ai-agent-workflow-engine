FROM python:3.12-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Python deps
RUN pip install --no-cache-dir \
    claude-agent-sdk \
    boto3 \
    google-cloud-storage \
    azure-storage-blob \
    azure-identity \
    deepagents

# Create a non-root user
RUN useradd -m -s /bin/bash agent

# Working directory owned by agent user
RUN mkdir -p /workspace/input /workspace/output && chown -R agent:agent /workspace

WORKDIR /workspace

COPY --chown=agent:agent storage/ /opt/storage/
COPY --chown=agent:agent runtime/ /opt/runtime/
COPY --chown=agent:agent skills/ /opt/skills/
COPY --chown=agent:agent entrypoint.py /opt/entrypoint.py

ENV PYTHONPATH="/opt"
ENV PLUGIN_NAME=""
ENV BUCKET=""
ENV RUN_PREFIX=""
ENV STORAGE_BACKEND="s3"
ENV S3_ENDPOINT=""
ENV GCP_PROJECT=""
ENV AZURE_STORAGE_ACCOUNT=""
ENV AZURE_STORAGE_CONNECTION_STRING=""
ENV AGENT_RUNTIME="claude"
ENV LLM_MODEL=""
ENV AWS_ACCESS_KEY_ID=""
ENV AWS_SECRET_ACCESS_KEY=""

# Run as non-root
USER agent

ENTRYPOINT ["python", "/opt/entrypoint.py"]
